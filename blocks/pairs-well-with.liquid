<style>
  #pairs-well-with-{{ block.id }} {
    width: 100%;
  }

  .product-addon-container-gm {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding-inline: clamp(16px, 4vw, 48px);
  }

  .cus-header-banner__title {
    grid-column: 1 / -1;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 8px 0;
    line-height: 1.1;
    color: #000000;
    text-align: center;
  }

  .product-addon-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 12px;
    background: #FFFFFF;
    height: 100%;
  }

  .product-addon-image {
    width: 70px;
    height: 70px;
    object-fit: contain;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .product-addon-image:hover {
    opacity: 0.8;
  }

  .product-addon-details {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .product-addon-title {
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    text-decoration: none;
    line-height: 1.3;
    margin: 0;
  }

  .product-addon-title:hover {
    opacity: 0.8;
  }

  .product-addon-price {
    font-size: 14px;
    color: #000000;
    font-weight: 600;
  }

  .stock-status {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
  }

  .stock-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
    flex-shrink: 0;
  }

  .stock-text {
    color: #000000;
    font-weight: 500;
  }

  .product-addon-button-column {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .product-addon-add-button {
    padding: 10px 20px;
    background-color: #000000;
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.5px;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
    min-width: 100px;
  }

  .product-addon-add-button:hover:not(:disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .product-addon-add-button:disabled {
    background-color: #9ca3af;
    cursor: not-allowed;
    transform: none;
  }

  @media (max-width: 749px) {
    .product-addon-container-gm {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .product-addon-item {
      gap: 12px;
      padding: 8px 0;
    }

    .product-addon-image {
      width: 60px;
      height: 60px;
    }

    .product-addon-add-button {
      padding: 8px 14px;
      font-size: 12px;
      min-width: 80px;
    }
  }
</style>

<div
  id="pairs-well-with-{{ block.id }}"
  data-product-id="{{ product.id }}"
  data-limit="{{ block.settings.products_to_show | default: 3 }}"
  data-heading="{{ block.settings.heading | default: 'Pairs well with' }}"
>
</div>

<script>
(function() {
  var container = document.getElementById('pairs-well-with-{{ block.id }}');
  if (!container) return;

  var productId = container.getAttribute('data-product-id');
  var limit     = container.getAttribute('data-limit');
  var heading   = container.getAttribute('data-heading');

  if (!productId) return;

  function formatMoney(cents) {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code | default: "USD" }}'
    }).format(cents / 100);
  }

  function updateCartBubble(count) {
    // Update every count span
    document.querySelectorAll('.cart-bubble__text-count').forEach(function(el) {
      el.textContent = count;
      el.classList.remove('hidden');
      el.removeAttribute('hidden');
    });

    // Make every bubble wrapper visible
    document.querySelectorAll('.cart-bubble').forEach(function(el) {
      el.classList.remove('visually-hidden');
      el.classList.remove('hidden');
      el.removeAttribute('hidden');
      el.style.display = '';
    });

    // Make every bubble text wrapper visible
    document.querySelectorAll('.cart-bubble__text').forEach(function(el) {
      el.classList.remove('hidden');
      el.removeAttribute('hidden');
    });
  }

  function addToCart(button, variantId) {
    if (button.disabled) return;
    var originalText = button.textContent.trim();
    button.disabled = true;
    button.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Cart add failed: ' + res.status);
      return res.json();
    })
    .then(function() {
      button.textContent = 'Added!';
      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 2000);

      // Get the section ID from cart-items-component
      var cartItemsComp = document.querySelector('cart-items-component[data-section-id]');
      var sectionId = cartItemsComp ? cartItemsComp.getAttribute('data-section-id') : null;

      // Always update cart count first via /cart.js
      fetch('/cart.js')
        .then(function(r) { return r.json(); })
        .then(function(cart) {
          updateCartBubble(cart.item_count);
        });

      if (!sectionId) {
        var dialog = document.querySelector('dialog[data-testid="cart-drawer-dialog"]');
        if (dialog) { dialog.showModal ? dialog.showModal() : dialog.setAttribute('open', ''); }
        return;
      }

      // Fetch fresh section HTML
      fetch('/?sections=' + sectionId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var html = data[sectionId];
          if (!html) return;

          var temp = document.createElement('div');
          temp.innerHTML = html;

          // Replace the entire cart-drawer__inner with fresh content
          var newInner = temp.querySelector('.cart-drawer__inner');
          var oldInner = document.querySelector('.cart-drawer__inner');
          if (newInner && oldInner) {
            oldInner.innerHTML = newInner.innerHTML;
          }
        })
        .catch(function() {})
        .finally(function() {
          // Open the dialog
          var dialog = document.querySelector('dialog[data-testid="cart-drawer-dialog"]');
          if (dialog) {
            if (!dialog.open) {
              dialog.showModal ? dialog.showModal() : dialog.setAttribute('open', '');
            }
          }
        });
    })
    .catch(function(err) {
      console.error('Add to cart error:', err);
      button.textContent = 'Error';
      setTimeout(function() {
        button.textContent = originalText;
        button.disabled = false;
      }, 2000);
    });
  }

  fetch('/recommendations/products.json?product_id=' + productId + '&limit=' + limit + '&intent=related')
    .then(function(res) { return res.json(); })
    .then(function(data) {
      var products = data.products;
      if (!products || products.length === 0) return;

      var html = '<div class="product-addon-container-gm">'
               + '<h2 class="cus-header-banner__title">' + heading + '</h2>';

      products.forEach(function(product) {
        // Pick first available variant
        var variant = null;
        for (var i = 0; i < product.variants.length; i++) {
          if (product.variants[i].available) { variant = product.variants[i]; break; }
        }
        if (!variant) return; // skip fully sold-out products

        var rawImage = '';
        if (variant.featured_image && variant.featured_image.src) {
          rawImage = variant.featured_image.src;
        } else if (product.featured_image && product.featured_image.src) {
          rawImage = product.featured_image.src;
        } else if (product.featured_image && typeof product.featured_image === 'string') {
          rawImage = product.featured_image;
        } else if (product.images && product.images.length > 0) {
          rawImage = product.images[0].src || product.images[0];
        }

        var image = '';
        if (rawImage) {
          if (rawImage.indexOf('//') === 0) rawImage = 'https:' + rawImage;
          image = rawImage.replace(/(\.[a-z]+)(\?.*)?$/i, '_160x160$1$2');
        }

        // Truncate title to 8 words
        var words = product.title.split(' ');
        var title = words.length > 8 ? words.slice(0, 8).join(' ') + '...' : product.title;

        var isFreeGift = product.tags && product.tags.indexOf('free-gift') !== -1;
        var priceHtml  = isFreeGift
          ? '<span class="product-addon-price">Free Gift</span>'
          : '<span class="product-addon-price">' + formatMoney(variant.price) + '</span>';

        var stockHtml = '';
        if (variant.inventory_quantity > 0 && variant.inventory_quantity <= 10) {
          stockHtml = '<div class="stock-status">'
            + '<div class="stock-indicator"></div>'
            + '<span class="stock-text">Only ' + variant.inventory_quantity + ' left</span>'
            + '</div>';
        }

        html += '<div class="product-addon-item">'
          +   '<a href="/products/' + product.handle + '">'
          +     '<img class="product-addon-image" src="' + image + '" alt="' + product.title + '" loading="lazy">'
          +   '</a>'
          +   '<div class="product-addon-details">'
          +     '<a href="/products/' + product.handle + '" class="product-addon-title">' + title + '</a>'
          +     priceHtml
          +     stockHtml
          +   '</div>'
          +   '<div class="product-addon-button-column">'
          +     '<button class="product-addon-add-button" data-variant-id="' + variant.id + '">Add</button>'
          +   '</div>'
          + '</div>';
      });

      html += '</div>';
      container.innerHTML = html;

      // Bind click events
      container.querySelectorAll('.product-addon-add-button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          addToCart(btn, btn.getAttribute('data-variant-id'));
        });
      });
    })
    .catch(function(err) {
      console.error('Pairs well with: failed to load recommendations', err);
    });
})();
</script>

{% schema %}
{
  "name": "Pairs Well With",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pairs well with"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Pairs Well With"
    }
  ]
}
{% endschema %}