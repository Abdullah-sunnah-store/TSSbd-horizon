{%- liquid
  assign sec          = section.settings
  assign heading      = sec.heading      | default: 'OUR MOST LOVED PRODUCTS'
  assign subheading   = sec.subheading   | default: 'What our Customers Say'
  assign heading_tag  = sec.heading_tag  | default: 'h2'
  assign heading_align = sec.heading_align | default: 'left'
  assign bg_color     = sec.bg_color     | default: '#ffffff'
  assign card_bg      = sec.card_bg      | default: '#f9f9f9'
  assign star_color   = sec.star_color   | default: '#f5a623'
  assign text_color   = sec.text_color   | default: '#222222'
  assign subtext_color = sec.subtext_color | default: '#666666'
  assign cards_visible = sec.cards_visible | default: 4
  assign card_gap      = sec.card_gap    | default: 20
  assign card_radius   = sec.card_radius | default: 12
  assign show_arrows   = sec.show_arrows
  assign show_dots     = sec.show_dots
  assign autoplay      = sec.autoplay
  assign autoplay_ms   = sec.autoplay_speed | times: 1000 | default: 4000
  assign img_height    = sec.img_height  | default: 260
  assign pt            = sec.padding_top    | default: 80
  assign pb            = sec.padding_bottom | default: 80
  assign pl            = sec.padding_left   | default: 40
  assign pr            = sec.padding_right  | default: 40
-%}

<style>
  #cr-{{ section.id }} {
    background: {{ bg_color }};
    padding: {{ pt }}px {{ pr }}px {{ pb }}px {{ pl }}px;
    --cr-star: {{ star_color }};
    --cr-card-bg: {{ card_bg }};
    --cr-text: {{ text_color }};
    --cr-sub: {{ subtext_color }};
    --cr-gap: {{ card_gap }}px;
    --cr-radius: {{ card_radius }}px;
    --cr-img-h: {{ img_height }}px;
    --cr-visible: {{ cards_visible }};
  }

  .cr-header {
    text-align: {{ heading_align }};
    margin-bottom: 32px;
  }
  .cr-title {
    font-size: var(--font-h2--size);
    font-weight: var(--font-h2--weight);
    line-height: var(--font-h2--line-height);
    letter-spacing: var(--font-h2--letter-spacing);
    color: var(--cr-text);
    margin: 0 0 6px;
    font-family: var(--font-heading--family);
  }
  .cr-subtitle {
    font-size: 0.95rem;
    color: var(--cr-sub);
    margin: 0;
    font-family: var(--font-body--family);
  }

  /* — Carousel — */
  .cr-carousel-wrap {
    position: relative;
  }
  .cr-track-outer {
    overflow: hidden;
  }
  .cr-track {
    display: flex;
    gap: var(--cr-gap);
    transition: transform 0.4s ease;
    will-change: transform;
    align-items: stretch;
  }
  .cr-card {
    background: var(--cr-card-bg);
    border-radius: var(--cr-radius);
    overflow: hidden;
    flex: 0 0 calc((100% - var(--cr-gap) * (var(--cr-visible) - 1)) / var(--cr-visible));
    display: flex;
    flex-direction: column;
    min-width: 0;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
    transition: box-shadow .25s, transform .25s;
  }
  .cr-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,.12);
    transform: translateY(-3px);
  }
  .cr-img-wrap {
    width: 100%;
    height: var(--cr-img-h);
    overflow: hidden;
    flex-shrink: 0;
    background: #eee;
  }
  .cr-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .cr-card:hover .cr-img-wrap img { transform: scale(1.04); }
  .cr-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e0d8;
    color: #bbb;
  }
  .cr-body {
    padding: 18px 18px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .cr-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 8px;
    font-size: 1rem;
    color: var(--cr-star);
  }
  .cr-star { line-height: 1; }
  .cr-review-title {
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    color: var(--cr-text);
    margin: 0 0 8px;
    font-family: var(--font-body--family);
  }
  .cr-review-text {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--cr-sub);
    margin: 0 0 14px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-body--family);
  }
  .cr-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: auto;
  }
  .cr-reviewer {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--cr-text);
    letter-spacing: 0.02em;
    font-family: var(--font-body--family);
  }
  .cr-product-link {
    font-size: 0.78rem;
    color: var(--cr-sub);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color .2s;
  }
  .cr-product-link:hover { color: var(--cr-text); }

  /* — Nav arrows — */
  .cr-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
    transition: background .2s, box-shadow .2s;
    color: #333;
  }
  .cr-arrow:hover { background: #f5f0ea; box-shadow: 0 4px 14px rgba(0,0,0,.14); }
  .cr-arrow--prev { left: -20px; }
  .cr-arrow--next { right: -20px; }
  .cr-arrow svg { width: 16px; height: 16px; }
  .cr-arrow[disabled] { opacity: 0.3; cursor: default; pointer-events: none; }

  /* — Dots — */
  .cr-dots {
    display: flex;
    justify-content: center;
    gap: 7px;
    margin-top: 20px;
  }
  .cr-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #ccc;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: background .2s, transform .2s;
  }
  .cr-dot.active {
    background: var(--cr-text);
    transform: scale(1.3);
  }

  /* — Mobile — */
  @media (max-width: 768px) {
    #cr-{{ section.id }} {
      padding: 40px 16px;
      --cr-visible: {{ sec.mobile_cards | default: 1 }};
      --cr-img-h: {{ sec.mobile_img_height | default: 200 }}px;
    }
    .cr-arrow--prev { left: -10px; }
    .cr-arrow--next { right: -10px; }
    /* .cr-title size handled by theme heading scale */
  }
</style>

<section id="cr-{{ section.id }}" class="cr-section">

  {%- if heading != blank or subheading != blank -%}
    <div class="cr-header">
      {%- if heading != blank -%}
        <{{ heading_tag }} class="cr-title">{{ heading }}</{{ heading_tag }}>
      {%- endif -%}
      {%- if subheading != blank -%}
        <p class="cr-subtitle">{{ subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="cr-carousel-wrap" id="cr-wrap-{{ section.id }}">
      <div class="cr-track-outer">
        <div class="cr-track" id="cr-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              {%- liquid
                assign r_img     = block.settings.image
                assign r_title   = block.settings.review_title
                assign r_text    = block.settings.review_text
                assign r_name    = block.settings.reviewer_name
                assign r_rating  = block.settings.rating | plus: 0
                assign r_product = block.settings.product_name
                assign r_url     = block.settings.product_url
                assign r_date    = block.settings.review_date
              -%}
              <div class="cr-card" {{ block.shopify_attributes }}>
                <div class="cr-img-wrap">
                  {%- if r_img != blank -%}
                    {{ r_img | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,400,600', alt: r_product }}
                  {%- else -%}
                    <div class="cr-img-placeholder">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                  {%- endif -%}
                </div>
                <div class="cr-body">
                  <div class="cr-stars">
                    {%- for i in (1..5) -%}
                      <span class="cr-star">{% if i <= r_rating %}★{% else %}☆{% endif %}</span>
                    {%- endfor -%}
                  </div>
                  {%- if r_title != blank -%}
                    <p class="cr-review-title">{{ r_title }}</p>
                  {%- endif -%}
                  {%- if r_text != blank -%}
                    <p class="cr-review-text">{{ r_text }}</p>
                  {%- endif -%}
                  <div class="cr-meta">
                    {%- if r_name != blank -%}
                      <span class="cr-reviewer">— {{ r_name }}{% if r_date != blank %} &middot; <span style="font-weight:400;text-transform:none;">{{ r_date }}</span>{% endif %}</span>
                    {%- endif -%}
                    {%- if r_url != blank -%}
                      <a class="cr-product-link" href="{{ r_url }}" target="_blank">
                        {{ r_product | default: 'View Product' }}
                      </a>
                    {%- elsif r_product != blank -%}
                      <span class="cr-product-link" style="text-decoration:none;">{{ r_product }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if show_arrows -%}
        <button class="cr-arrow cr-arrow--prev" id="cr-prev-{{ section.id }}" aria-label="Previous" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="cr-arrow cr-arrow--next" id="cr-next-{{ section.id }}" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}
    </div>

    {%- if show_dots -%}
      <div class="cr-dots" id="cr-dots-{{ section.id }}"></div>
    {%- endif -%}
  {%- endif -%}


</section>

<script>
(function () {
  const sid = '{{ section.id }}';
  const visible = {{ cards_visible }};
  const gapPx   = {{ card_gap }};
  const autoplay = {{ autoplay | json }};
  const autoMs   = {{ autoplay_ms }};
  const showDots = {{ show_dots | json }};

  const track = document.getElementById('cr-track-' + sid);
  if (!track) return;

  let cards   = Array.from(track.querySelectorAll('.cr-card'));
  let current = 0;
  let timer   = null;

  function totalSlides() {
    return Math.max(0, cards.length - visible);
  }

  function goTo(idx) {
    if (!cards.length) return;
    const max = totalSlides();
    current = Math.max(0, Math.min(idx, max));

    const cardW = cards[0].getBoundingClientRect().width + gapPx;
    track.style.transform = 'translateX(-' + (current * cardW) + 'px)';

    const prevBtn = document.getElementById('cr-prev-' + sid);
    const nextBtn = document.getElementById('cr-next-' + sid);
    if (prevBtn) prevBtn.disabled = current === 0;
    if (nextBtn) nextBtn.disabled = current >= max;

    if (showDots) updateDots();
  }

  function updateDots() {
    const dotsWrap = document.getElementById('cr-dots-' + sid);
    if (!dotsWrap) return;
    const max = totalSlides();
    dotsWrap.innerHTML = '';
    for (let i = 0; i <= max; i++) {
      const d = document.createElement('button');
      d.className = 'cr-dot' + (i === current ? ' active' : '');
      d.setAttribute('aria-label', 'Slide ' + (i + 1));
      d.addEventListener('click', function () { goTo(i); resetTimer(); });
      dotsWrap.appendChild(d);
    }
  }

  function resetTimer() {
    clearInterval(timer);
    if (autoplay) {
      timer = setInterval(function () {
        const max = totalSlides();
        goTo(current < max ? current + 1 : 0);
      }, autoMs);
    }
  }

  // Arrow buttons
  const prev = document.getElementById('cr-prev-' + sid);
  const next = document.getElementById('cr-next-' + sid);
  if (prev) prev.addEventListener('click', function () { goTo(current - 1); resetTimer(); });
  if (next) next.addEventListener('click', function () { goTo(current + 1); resetTimer(); });

  // Touch / drag
  let startX = 0, dragging = false;
  track.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; dragging = true; }, { passive: true });
  track.addEventListener('touchend', function (e) {
    if (!dragging) return;
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
    dragging = false;
    resetTimer();
  });

  goTo(0);
  resetTimer();

  // Re-init on resize
  let resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { goTo(current); }, 150);
  });
})();
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section-customer-reviews",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Most Loved Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What our Customers Say"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p",  "label": "Paragraph" }
      ]
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "id": "cards_visible",
      "label": "Cards visible (desktop)",
      "min": 1, "max": 6, "step": 1,
      "default": 4
    },
    {
      "type": "range",
