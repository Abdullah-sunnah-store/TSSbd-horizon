{{ 'gifts-keep-giving.css' | asset_url | stylesheet_tag }}

<section class="gifts-keep-giving" style="
  --heading-color: {{ section.settings.heading_color }};
  --text-color: {{ section.settings.text_color }};
  --badge-bg: {{ section.settings.badge_bg_color }};
  --badge-text: {{ section.settings.badge_text_color }};
  --section-bg: {{ section.settings.section_bg_color }};
  --section-padding-top: {{ section.settings.padding_top }}px;
  --section-padding-bottom: {{ section.settings.padding_bottom }}px;
">
  <div class="gifts-keep-giving__inner">
    <div class="gifts-keep-giving__text">
      {%- if section.settings.heading != blank -%}
        <h2 class="gifts-keep-giving__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="gifts-keep-giving__description">{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="gifts-keep-giving__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="gifts-keep-giving__images">
      {%- for block in section.blocks -%}
        <div class="gifts-keep-giving__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <a href="{{ block.settings.link }}" class="gifts-keep-giving__card-link">
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '400, 600, 800',
                  class: 'gifts-keep-giving__card-img',
                  alt: block.settings.label
              }}
              {%- if block.settings.label != blank -%}
                <span class="gifts-keep-giving__badge">{{ block.settings.label }}</span>
              {%- endif -%}
            </a>
          {%- else -%}
            <div class="gifts-keep-giving__card-placeholder">
              {{ 'image' | placeholder_svg_tag: 'gifts-keep-giving__card-img placeholder' }}
              {%- if block.settings.label != blank -%}
                <span class="gifts-keep-giving__badge">{{ block.settings.label }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .gifts-keep-giving {
    background-color: var(--section-bg);
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  .gifts-keep-giving__inner {
    display: flex;
    align-items: center;
    gap: 32px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0px;
  }

  .gifts-keep-giving__text {
    flex: 0 0 auto;
    width: 260px;
    min-width: 200px;
  }

  .gifts-keep-giving__heading {
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    color: var(--heading-color);
    line-height: 1.15;
    margin: 0 0 16px;
  }

  .gifts-keep-giving__description {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-color);
    margin: 0 0 20px;
  }

  .gifts-keep-giving__btn {
    display: inline-block;
    padding: 10px 22px;
    background-color: var(--badge-bg);
    color: var(--badge-text);
    border-radius: 4px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .gifts-keep-giving__images {
    display: flex;
    flex: 1 1 auto;
    gap: 16px;
    overflow: hidden;
  }

  .gifts-keep-giving__card {
    flex: 1 1 0;
    min-width: 0;
    border-radius: 16px;
    overflow: visible;
    position: relative;
    padding-bottom: 21px;
  }

  .gifts-keep-giving__card-link,
  .gifts-keep-giving__card-placeholder {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
  }

  .gifts-keep-giving__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  .gifts-keep-giving__card-img.placeholder {
    aspect-ratio: 4/3;
  }

  .gifts-keep-giving__badge {
    position: absolute;
    bottom: -21px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--badge-bg);
    color: var(--badge-text);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 10px 24px;
    border-radius: 4px;
    white-space: nowrap;
    text-align: center;
    z-index: 2;
  }

  @media screen and (max-width: 768px) {
    .gifts-keep-giving__inner {
      flex-direction: column;
      gap: 24px;
    }

    .gifts-keep-giving__text {
      width: 100%;
    }

    .gifts-keep-giving__images {
      width: 100%;
    }
  }

  @media screen and (max-width: 480px) {
    .gifts-keep-giving__images {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Gifts Keep Giving",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gifts that keep giving"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "From daily content tailored to their interests to a lifetime of stories, these gifts are ways to connect with the people you care about, show them you appreciate their knowledge and wisdom, and celebrate what makes them uncommon."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a5c3a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background color",
      "default": "#1a5c3a"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge label",
          "default": "daily discovery gifts"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gifts Keep Giving",
      "blocks": [
        {
          "type": "image_card",
          "settings": {
            "label": "daily discovery gifts"
          }
        },
        {
          "type": "image_card",
          "settings": {
            "label": "guided memoir"
          }
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
