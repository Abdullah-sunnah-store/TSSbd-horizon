{%- liquid
  assign items_per_row    = section.settings.items_per_row | plus: 0
  assign show_see_all     = section.settings.show_see_all
  assign see_all_label    = section.settings.see_all_label
  assign mobile_limit     = section.settings.mobile_limit | plus: 0
  assign image_size       = section.settings.image_size | append: '%'
  assign row_gap          = section.settings.row_gap | append: 'px'
  assign title_size       = 'var(--font-h2--size)'
  assign subheading_size  = section.settings.subheading_font_size | append: 'px'
  assign label_size       = section.settings.label_font_size | append: 'px'
  assign label_weight     = section.settings.label_font_weight
  assign header_spacing   = section.settings.header_spacing | append: 'px'
  assign section_width    = section.settings.section_width
  assign custom_width     = section.settings.custom_width
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--{% if section_width == 'custom' %}page-width{% else %}{{ section_width }}{% endif %} color-{{ section.settings.color_scheme }} spotlight spacing-style"
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% if section_width == 'custom' and custom_width > 0 %}max-width: {{ custom_width }}px; margin-inline: auto; width: 100%;{% endif %}
  "
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="spotlight__header" style="margin-bottom: {{ header_spacing }};">
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_tag }} class="spotlight__title" style="font-size: {{ title_size }}; font-weight: var(--font-h2--weight);">
          {{- section.settings.heading -}}
        </{{ section.settings.heading_tag }}>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="spotlight__subheading" style="font-size: {{ subheading_size }};">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div
    class="spotlight__grid"
    style="
      --spotlight-columns: {{ items_per_row }};
      --spotlight-image-size: {{ image_size }};
      --spotlight-row-gap: {{ row_gap }};
      --spotlight-label-size: {{ label_size }};
      --spotlight-label-weight: {{ label_weight }};
    "
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign item_image = block.settings.image
        assign item_label = block.settings.label
        assign item_link  = block.settings.link
        assign item_collection = block.settings.collection
        assign href = item_link
        if item_collection != blank and item_link == blank
          assign href = item_collection.url
        endif
        if item_label == blank and item_collection != blank
          assign item_label = item_collection.title
        endif
      -%}
      <div
        class="spotlight__item{% if forloop.index > mobile_limit %} spotlight__item--hidden-mobile{% endif %}"
        {{ block.shopify_attributes }}
      >
        <a class="spotlight__item-link" {% if href != blank %}href="{{ href }}"{% endif %}>
          <div class="spotlight__image-wrap">
            {%- if item_image != blank -%}
              {{ item_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 300, 400', class: 'spotlight__image', alt: item_label }}
            {%- elsif item_collection != blank and item_collection.featured_image != blank -%}
              {{ item_collection.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 300, 400', class: 'spotlight__image', alt: item_label }}
            {%- else -%}
              <div class="spotlight__placeholder">{{ 'image' | placeholder_svg_tag: 'spotlight__placeholder-svg' }}</div>
            {%- endif -%}
          </div>
          {%- if item_label != blank -%}
            <span class="spotlight__label">{{ item_label }}</span>
          {%- endif -%}
        </a>
      </div>
    {%- endfor -%}

    {%- if section.blocks.size == 0 -%}
      {%- for i in (1..8) -%}
        <div class="spotlight__item">
          <div class="spotlight__item-link">
            <div class="spotlight__image-wrap">
              <div class="spotlight__placeholder">{{ 'image' | placeholder_svg_tag: 'spotlight__placeholder-svg' }}</div>
            </div>
            <span class="spotlight__label">Item {{ i }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if show_see_all and section.blocks.size > mobile_limit -%}
    <div class="spotlight__footer">
      <button class="spotlight__see-all" type="button" aria-controls="spotlight-modal-{{ section.id }}" aria-expanded="false">
        {{ see_all_label | default: 'See All' }}
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  {%- endif -%}
</div>

{%- if show_see_all and section.blocks.size > mobile_limit -%}
  <div id="spotlight-modal-{{ section.id }}" class="spotlight-modal" role="dialog" aria-modal="true" aria-label="{{ section.settings.heading | default: 'Spotlight' }}" hidden>
    <div class="spotlight-modal__inner">
      <button class="spotlight-modal__close" type="button" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="spotlight-modal__grid">
        {%- for block in section.blocks -%}
          {%- liquid
            assign item_image = block.settings.image
            assign item_label = block.settings.label
            assign item_link  = block.settings.link
            assign item_collection = block.settings.collection
            assign href = item_link
            if item_collection != blank and item_link == blank
              assign href = item_collection.url
            endif
            if item_label == blank and item_collection != blank
              assign item_label = item_collection.title
            endif
          -%}
          <div class="spotlight-modal__item">
            <a class="spotlight__item-link" {% if href != blank %}href="{{ href }}"{% endif %}>
              <div class="spotlight__image-wrap">
                {%- if item_image != blank -%}
                  {{ item_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 300, 400', class: 'spotlight__image', alt: item_label }}
                {%- elsif item_collection != blank and item_collection.featured_image != blank -%}
                  {{ item_collection.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '200, 300, 400', class: 'spotlight__image', alt: item_label }}
                {%- else -%}
                  <div class="spotlight__placeholder">{{ 'image' | placeholder_svg_tag: 'spotlight__placeholder-svg' }}</div>
                {%- endif -%}
              </div>
              {%- if item_label != blank -%}
                <span class="spotlight__label">{{ item_label }}</span>
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var trigger = section.querySelector('.spotlight__see-all');
    var modal = document.getElementById('spotlight-modal-{{ section.id }}');
    if (!trigger || !modal) return;
    var closeBtn = modal.querySelector('.spotlight-modal__close');
    function openModal() { modal.hidden = false; document.body.style.overflow = 'hidden'; trigger.setAttribute('aria-expanded', 'true'); closeBtn && closeBtn.focus(); }
    function closeModal() { modal.hidden = true; document.body.style.overflow = ''; trigger.setAttribute('aria-expanded', 'false'); trigger.focus(); }
    trigger.addEventListener('click', openModal);
    closeBtn && closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape' && !modal.hidden) closeModal(); });
  })();
</script>

{% style %}
  #shopify-section-{{ section.id }} .spotlight { text-align: center; }

  #shopify-section-{{ section.id }} .spotlight__title {
    letter-spacing: var(--font-h2--letter-spacing);
    line-height: var(--font-h2--line-height);
    margin: 0 0 1.2rem;
    font-weight: var(--font-h2--weight);
    font-family: var(--font-heading--family);
  }

  #shopify-section-{{ section.id }} .spotlight__subheading {
    color: currentColor;
    opacity: 0.75;
    margin: 0;
    max-width: 70ch;
    margin-inline: auto;
    font-family: var(--font-body--family);
  }

  #shopify-section-{{ section.id }} .spotlight__grid {
    display: grid;
    grid-template-columns: repeat(var(--spotlight-columns, 8), 1fr);
    gap: var(--spotlight-row-gap, 4rem) 0;
  }

  #shopify-section-{{ section.id }} .spotlight__item-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    padding: 0 0.8rem;
  }

  #shopify-section-{{ section.id }} .spotlight__image-wrap {
    width: var(--spotlight-image-size, 70%);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .spotlight__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
    image-rendering: -webkit-optimize-contrast;
    -ms-interpolation-mode: bicubic;
  }

  #shopify-section-{{ section.id }} .spotlight__item-link:hover .spotlight__image { transform: scale(1.08); }

  #shopify-section-{{ section.id }} .spotlight__placeholder-svg { width: 60%; height: 60%; opacity: 0.3; }

  #shopify-section-{{ section.id }} .spotlight__label {
    font-size: var(--spotlight-label-size, 1.2rem);
    font-weight: var(--spotlight-label-weight, 400);
    text-align: center;
    line-height: 1.4;
    color: currentColor;
    font-family: var(--font-body--family);
  }

  #shopify-section-{{ section.id }} .spotlight__footer { margin-top: 3.2rem; display: flex; justify-content: center; }

  #shopify-section-{{ section.id }} .spotlight__see-all {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 10px 20px;
    border: 1px solid currentColor;
    border-radius: 10rem;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    color: inherit;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .spotlight__see-all:hover { opacity: 0.7; }

  @media screen and (max-width: 1199px) {
    #shopify-section-{{ section.id }} .spotlight__grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .spotlight__footer { display: none; }
    #shopify-section-{{ section.id }} .spotlight__item--hidden-mobile { display: block; }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .spotlight__grid { grid-template-columns: repeat(3, 1fr); }
    #shopify-section-{{ section.id }} .spotlight__item--hidden-mobile { display: none; }
  }

  /* Modal */
  .spotlight-modal { position: fixed; inset: 0; z-index: 9999; background: #fff; overflow-y: auto; -webkit-overflow-scrolling: touch; }
  .spotlight-modal__inner { position: relative; padding: 6rem 2rem 4rem; max-width: 480px; margin: 0 auto; }
  .spotlight-modal__close { position: fixed; top: 1.6rem; right: 1.6rem; width: 4rem; height: 4rem; display: flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; color: inherit; z-index: 10000; padding: 0; }
  .spotlight-modal__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3.2rem 1.6rem; }
  .spotlight-modal__item .spotlight__item-link { align-items: center; }
  .spotlight-modal__item .spotlight__label { text-align: center; }
  @media screen and (min-width: 768px) { .spotlight-modal { display: none !important; } }
{% endstyle %}

{% schema %}
{
  "name": "Spotlight",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spotlight"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Classic silhouettes and cutting-edge innovation to build your game from the ground up."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Heading font size (px)",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Heading font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extrabold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "900"
    },
    {
      "type": "range",
      "id": "subheading_font_size",
      "label": "Subheading font size (px)",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Item label font size (px)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "label_font_weight",
      "label": "Item label font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "label": "Items per row (desktop)",
      "min": 4,
      "max": 10,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size (%)",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 70
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Row gap (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below heading (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_limit",
      "label": "Items shown before See All",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_see_all",
      "label": "Show See All button on mobile",
      "default": true
    },
    {
      "type": "text",
      "id": "see_all_label",
      "label": "See All button label",
      "default": "See All"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" },
        { "value": "custom", "label": "Custom (px)" }
      ],
      "default": "page-width"
    },
    {
      "type": "number",
      "id": "custom_width",
      "label": "Custom width (px)",
      "info": "e.g. 1200 — only applies when Section width is set to Custom",
      "default": 1200
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Spotlight item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (optional)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (overrides collection link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Spotlight",
      "blocks": [
        { "type": "item", "settings": { "label": "Item 1" } },
        { "type": "item", "settings": { "label": "Item 2" } },
        { "type": "item", "settings": { "label": "Item 3" } },
        { "type": "item", "settings": { "label": "Item 4" } },
        { "type": "item", "settings": { "label": "Item 5" } },
        { "type": "item", "settings": { "label": "Item 6" } },
        { "type": "item", "settings": { "label": "Item 7" } },
        { "type": "item", "settings": { "label": "Item 8" } }
      ]
    }
  ]
}
{% endschema %}
