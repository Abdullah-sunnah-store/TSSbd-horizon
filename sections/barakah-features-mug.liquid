{% comment %}
  Barakah Features Section
  
  Usage: Add this file to your theme's sections folder
  Customize settings in the theme editor
{% endcomment %}

<style>
  .barakah-features {
    padding: 4rem 2rem;
    background-color: {{ section.settings.background_color }};
  }

  .barakah-features__container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .barakah-features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
  }

  .barakah-features__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .barakah-features__icon-wrapper {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    background-color: {{ section.settings.icon_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: transform 0.3s ease;
  }

  .barakah-features__item:hover .barakah-features__icon-wrapper {
    transform: translateY(-4px);
  }

  .barakah-features__icon {
    width: 4rem;
    height: 4rem;
    color: {{ section.settings.icon_color }};
  }

  .barakah-features__title {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    color: {{ section.settings.title_color }};
  }

  .barakah-features__description {
    font-size: 1.6rem;
    line-height: 1.6;
    color: {{ section.settings.description_color }};
    margin: 0;
    max-width: 320px;
  }

  @media (max-width: 768px) {
    .barakah-features {
      padding: 3rem 1rem;
    }

    .barakah-features__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<section class="barakah-features">
  <div class="barakah-features__container">
    <div class="barakah-features__grid">
      {% for block in section.blocks %}
        <div class="barakah-features__item" {{ block.shopify_attributes }}>
          <div class="barakah-features__icon-wrapper">
            {% case block.settings.icon %}
              {% when 'gift' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path>
                </svg>
              {% when 'heart' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                </svg>
              {% when 'truck' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
                </svg>
              {% when 'shield' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              {% when 'star' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                </svg>
              {% when 'sparkles' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                </svg>
              {% when 'check-circle' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              {% when 'lightning' %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              {% else %}
                <svg class="barakah-features__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            {% endcase %}
          </div>
          
          <h3 class="barakah-features__title">{{ block.settings.title }}</h3>
          <p class="barakah-features__description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Barakah Features",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background color",
      "default": "#F5E6D3"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#6B7280"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "gift",
              "label": "Gift"
            },
            {
              "value": "heart",
              "label": "Heart"
            },
            {
              "value": "truck",
              "label": "Truck (Shipping)"
            },
            {
              "value": "shield",
              "label": "Shield (Protection)"
            },
            {
              "value": "star",
              "label": "Star"
            },
            {
              "value": "sparkles",
              "label": "Sparkles"
            },
            {
              "value": "check-circle",
              "label": "Check Circle"
            },
            {
              "value": "lightning",
              "label": "Lightning (Fast)"
            }
          ],
          "default": "gift"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barakah Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "gift",
            "title": "Premium Quality",
            "description": "Elegant gold foil calligraphy on premium ceramic, built to last for years"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "heart",
            "title": "Meaningful Designs",
            "description": "Each mug features authentic Islamic calligraphy to inspire daily reflection"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "truck",
            "title": "Fast Shipping",
            "description": "Same-day dispatch with free shipping on all orders over $50"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shield",
            "title": "Satisfaction Guaranteed",
            "description": "30-day returns and dedicated customer support for complete peace of mind"
          }
        }
      ]
    }
  ]
}
{% endschema %}
